# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fnews:changeme@db:5432/fnews

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Email – outbound (SMTP) ─────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@example.com
EMAIL_SMTP_PASS=changeme
EMAIL_FROM=fnews@example.com
EMAIL_TO=you@example.com

# ─── Email – inbound (IMAP) ──────────────────────────────────────────────────
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=you@example.com
EMAIL_IMAP_PASS=changeme

# ─── LLM backend ─────────────────────────────────────────────────────────────
# Choices: ollama | vllm | llamacpp
LLM_BACKEND=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL_NAME=llama3

# ─── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ─── Alerts ──────────────────────────────────────────────────────────────────
ALERT_THRESHOLD=70
ALERT_MIN_SOURCES=2

# ─── Source & watchlist config ────────────────────────────────────────────────
SOURCE_CONFIG_PATH=/app/config/sources.yaml
WATCHLIST_CONFIG_PATH=/app/config/watchlist.yaml

# ─── API auth ────────────────────────────────────────────────────────────────
API_KEY=changeme-api-key-here

# ─── Daily briefing schedule (cron syntax, UTC) ───────────────────────────────
BRIEFING_CRON=0 7 * * *

# ─── Ingestion schedule (every N minutes) ────────────────────────────────────
INGESTION_INTERVAL_MINUTES=30

# ─── Blob storage ────────────────────────────────────────────────────────────
BLOB_STORE_PATH=/data/blobs

# ─── Chunk settings ──────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── Self-evaluation ─────────────────────────────────────────────────────────
EVAL_WINDOW_DAYS=7

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
